<div
  class="email-container"
  style="max-width: 620px; margin: 24px auto; background: #ffffff; border-radius: 14px; overflow: hidden; box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08); border: 1px solid #e7edf5;"
>
  <div
    class="header"
    style="background: linear-gradient(135deg, #b91c1c 0%, #c2410c 100%); color: #ffffff; padding: 28px 24px; text-align: center;"
  >
    <p style="margin: 0 0 8px 0; font-size: 12px; letter-spacing: 1.6px; text-transform: uppercase; opacity: 0.9;">
      Growlearnhub Security
    </p>
    <h1 style="margin: 0; font-size: 28px; font-weight: 700; line-height: 1.25; color: #ffffff;">
      Password Reset
    </h1>
  </div>

  <div
    class="content"
    style="padding: 30px 24px; color: #1f2937; line-height: 1.7; font-size: 17px;"
  >
    <p style="margin: 0 0 16px 0;">
      Hello, <strong>{{username}}</strong>
    </p>

    <p style="margin: 0 0 18px 0; color: #374151;">
      We received a request to reset your Growlearnhub password. Use the one-time code below to proceed:
    </p>

    <div
      class="otp-box"
      style="background: #fff7ed; border: 1px solid #fed7aa; color: #c2410c; font-size: 38px; font-weight: 800; text-align: center; padding: 18px 20px; border-radius: 12px; letter-spacing: 8px; margin: 20px 0 24px 0;"
    >
      {{otp}}
    </div>

    <p style="margin: 0 0 12px 0; color: #4b5563; font-size: 14px;">
      This code expires in 5 minutes. For your security, do not share this code with anyone.
    </p>

    <p style="margin: 0 0 20px 0; color: #4b5563; font-size: 14px;">
      If you did not request a password reset, please ignore this email. Your account remains secure.
    </p>

    <p style="margin: 0;">
      Best regards,<br />
      <strong>The Growlearnhub Team</strong>
    </p>
  </div>

  {{> footer}}
</div>
