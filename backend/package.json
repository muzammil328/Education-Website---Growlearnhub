{
  "name": "@muzammil/education-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "mailpit & redis-server & nodemon --exec tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/backend/src/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "seed": "tsx src/scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "build:vercel-api": "node scripts/build-vercel-api.mjs",
    "postinstall": "node scripts/build-vercel-api.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@muzammil328/db": "1.0.36",
    "@muzammil328/education-packages": "workspace:*",
    "@muzammil328/integrations": "1.0.21",
    "@muzammil328/server": "^1.0.6",
    "@muzammil328/services": "1.0.21",
    "@muzammil328/trpc": "^1.0.3",
    "@muzammil328/types": "^1.0.16",
    "@muzammil328/utils": "1.0.16",
    "@trpc/server": "^11.16.0",
    "@types/cookie-parser": "^1.4.10",
    "axios": "^1.16.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-serve-static-core": "^0.1.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "mongoose": "^8.9.4",
    "qs": "^6.15.0",
    "socket.io": "^4.8.3",
    "zod": "^3.23.0"
  },
  "_moduleAliases": {
    "@": "src",
    "@config": "src/config",
    "@database": "src/database",
    "@middleware": "src/middleware",
    "@models": "src/database/models",
    "@modules": "src/database/modules",
    "@foundation": "src/foundation",
    "@constants": "src/shared/constants",
    "@enums": "src/shared/enums",
    "@types": "src/types"
  },
  "overrides": {
    "cookie": "^1.0.2",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.2.5",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2"
  }
}
