{
  "name": "@muzammil328/education-packages",
  "version": "1.0.29",
  "description": "Shared TypeScript types, enums, and Zod schemas for the education platform",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./enums": {
      "types": "./src/enums/index.ts",
      "import": "./src/enums/index.ts",
      "default": "./src/enums/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    }
  },
  "dependencies": {
    "@muzammil328/types": "1.0.5",
    "mongoose": "^8.11.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
